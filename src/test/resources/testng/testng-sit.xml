<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium-TestNG-Java-TDD" parallel="methods" thread-count="1" verbose="1">
    <listeners>
        <listener class-name="com.seleniumproject.listeners.EnvironmentListener"/>
        <listener class-name="com.seleniumproject.listeners.ExtentReportListener"/>
        <listener class-name="com.seleniumproject.listeners.AllureReportListener"/>
    </listeners>

    <test name="SIT_Execution">
        <classes>
            <class name="com.seleniumproject.tests.LoginPageTests"/>
            <class name="com.seleniumproject.tests.DashboardPageTests"/>
        </classes>
    </test>
</suite>